{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/skybox-enforce.js"],
            "statusMessage": "Checking skybox..."
          }
        ]
      },
      {
        "matcher": "skyline_run",
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/skybox-enforce.js"],
            "statusMessage": "Checking skybox..."
          }
        ]
      }
    ]
  }
}
